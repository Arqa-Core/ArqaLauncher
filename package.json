{
  "name": "arqa-launcher",
  "version": "0.1.0",
  "description": "PS2-inspired Electron frontend for Bazzite emulation",
  "main": "main.js",
  "scripts": {
    "start": "npx electron-forge start",
    "debug": "node scripts/debug-launcher.js",
    "package": "npx electron-forge package",
    "make": "npx electron-forge make",
    "build": "node scripts/build.js",
    "build:make": "node scripts/build.js --make",
    "scan": "node scripts/scan-roms.js",
    "validate": "node scripts/validate-setup.js",
    "settings": "node scripts/show-settings.js",
    "reset-settings": "node scripts/reset-settings.js"
  },
  "keywords": [
    "electron",
    "ps2",
    "emulation",
    "bazzite",
    "launcher"
  ],
  "author": "Arqa Launcher",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/core": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^42.4.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
